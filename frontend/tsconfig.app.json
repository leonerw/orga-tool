{
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "declarationMap": true,

    "jsx": "react-jsx",

    "target": "ES2020",
    "lib": ["DOM", "DOM.Iterable", "ES2020"],

    "module": "ESNext",
    "moduleResolution": "Bundler",

    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    "strict": true,
    "skipLibCheck": true,

    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },

    "outDir": "dist-ts"
  },
  "include": ["src"]
}
